# ----------------------------------------------------------------------------
# Copy to .env and fill in. Never commit the real .env.
# ----------------------------------------------------------------------------

# Signing key for JWTs. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Async SQLAlchemy URL. For docker-compose this points at the `db` service.
# Local (no docker) Postgres example:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/appdb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/appdb

# Where the React SPA is served (used for CORS + the post-Google-login redirect).
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS backend (used to build the Google OAuth redirect URI).
BACKEND_URL=http://localhost:8000

# Google OAuth 2.0 credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be:  {BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie flags. Set COOKIE_SECURE=true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# "dev" or "prod" — dev enables Swagger docs and relaxes a few defaults.
ENVIRONMENT=dev
